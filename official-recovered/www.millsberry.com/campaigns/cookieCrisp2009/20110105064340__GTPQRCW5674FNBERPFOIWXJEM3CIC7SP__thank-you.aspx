<script language="javascript" type="text/javascript">
    function dwnIcn() {
        var chosen = document.buddy.icon.value;
        var optionselected = -1;

        for (var i = 0; i < document.buddy.icon.length; i++) {
            if (document.buddy.icon[i].checked) {
                chosen = document.buddy.icon[i].value;
                optionselected = i;
            }
        }

        if (optionselected == -1) {
            alert("You must select a buddy icon.");
            return false;
        }
        else
            newwin = window.open("downloads/icn-" + chosen + ".gif");
    }
