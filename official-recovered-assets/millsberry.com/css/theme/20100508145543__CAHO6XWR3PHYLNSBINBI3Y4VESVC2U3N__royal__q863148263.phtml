body {
	background-color: #E6ECFF; /*pale blue*/
}

#top {
   background: transparent url('http://graphics.millsberry.com/site_gfx/layout/shadow_top_3.gif') no-repeat 0 22px;
}
		
#body {
	background: transparent url('http://graphics.millsberry.com/site_gfx/layout/shadow_body_3.gif') repeat-y;
}
#bottom {
	background: #001E7B url('http://graphics.millsberry.com/site_gfx/layout/shadow_bottom_3.gif') no-repeat;
}

#top #layout_head #stripe {
	background-color: #7f98e5;
    border-top: 2px solid #0D1E7D;
    border-left: 2px solid #0D1E7D;
    border-right: 2px solid #0D1E7D;
}

#top #layout_head #stripe input {
	background-color: #E6ECFF;
}

#body #layout_body {
	border: 2px solid #0D1E7D;
	background: #7f98e5 url('http://graphics.millsberry.com/site_gfx/layout/layoutBodyBackground.gif')  repeat-y;
}

#body #layout_body-nonav {
	border: 2px solid #0D1E7D;
	background-color: #7f98e5;
}

#body #layout_body #side_nav {
	background-color: #7f98e5;
}

#body  #footer {
	background-color: #001E7B;
}

#gazette_banner {
	background-color: #F1F1F1;
}
#interior {
	background-color: #316BF0;
}
#coach_link #coach {
	background-color: #F1F1F1;
}
#interior_stripe, .header_stripe_TD, #syndicated_ad {
	background-color: #001E7B;
}

a.page_link:hover {
	background-color: #BBCAFB;
	color: #000099;
}
span.page_selected {
	background-color: silver;
}
span.page_spacer {
	color: gray;
}
